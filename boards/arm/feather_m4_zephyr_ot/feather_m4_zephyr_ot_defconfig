# Custom defconfig for the Zephyr Feather M4 handheld unit
# All major configuration has been moved here so that all units
# will have the same base level of functionality
# 120MHz ATSAMD51
# IPS 240x240 round display
# Two pushbuttons
# 3 WS2812 LEDs (one on Adafruit Feather plus two on carrier board)
# SD Card (on rear of Adafruit display module)

CONFIG_SOC_ATMEL_SAMD5X_OSCULP32K_AS_MAIN=y
CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=120000000

CONFIG_BOOTLOADER_BOSSA=y
CONFIG_BOOTLOADER_BOSSA_ADAFRUIT_UF2=y
CONFIG_BUILD_OUTPUT_HEX=y
CONFIG_BUILD_OUTPUT_UF2=y

CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
CONFIG_UART_INTERRUPT_DRIVEN=y
CONFIG_STDOUT_CONSOLE=y
CONFIG_UART_LINE_CTRL=y 

# Enable USB CDC ACM for console output
CONFIG_USB_DEVICE_STACK_NEXT=y
CONFIG_CDC_ACM_SERIAL_INITIALIZE_AT_BOOT=y
CONFIG_CDC_ACM_SERIAL_PID=0x0004
CONFIG_CDC_ACM_SERIAL_PRODUCT_STRING="USBD console sample"
CONFIG_USBD_LOG_LEVEL_OFF=y
CONFIG_USBD_CDC_ACM_LOG_LEVEL_OFF=y

CONFIG_PRINTK=y

# Configure SPI
CONFIG_GPIO=y
CONFIG_SPI=y

# Enable SD card support
CONFIG_SDHC=y
CONFIG_DISK_ACCESS=y
CONFIG_DISK_DRIVER_SDMMC=y
CONFIG_FILE_SYSTEM=y
CONFIG_FAT_FILESYSTEM_ELM=y
CONFIG_FS_LOG_LEVEL_DBG=y

# This is to enable our custom driver
CONFIG_WS2812_COMMON=y

# set log level 2 to reduce log output (warning and errors)
CONFIG_LOG=y
CONFIG_LOG_DEFAULT_LEVEL=2
CONFIG_PINCTRL_LOG_LEVEL_DBG=y 

CONFIG_INPUT=y
CONFIG_GPIO_SAM0=y

# Set stack sizes for main thread and system workqueue
# As we are using LVGL we need quite large stacks for both
CONFIG_MAIN_STACK_SIZE=8192
CONFIG_SYSTEM_WORKQUEUE_STACK_SIZE=4096

# Enable display drivers and LVGL
CONFIG_DISPLAY=y
CONFIG_DISPLAY_LOG_LEVEL_ERR=y

CONFIG_LVGL=y
CONFIG_LV_Z_MEM_POOL_SIZE=40000
CONFIG_LV_Z_VDB_SIZE=10

# Display needs data in BGR format, with endianess swapped for SPI
CONFIG_LV_COLOR_DEPTH_16=y
CONFIG_LV_COLOR_16_SWAP=y

CONFIG_SYS_CLOCK_EXISTS=y
CONFIG_LV_CONF_MINIMAL=y
CONFIG_LV_USE_LABEL=y
CONFIG_LV_USE_BUTTON=y
CONFIG_LV_USE_CHART=y
CONFIG_LV_USE_IMAGE=y
CONFIG_LV_USE_THEME_DEFAULT=y
CONFIG_LV_FONT_MONTSERRAT_28=y
CONFIG_TICKLESS_KERNEL=n
CONFIG_LV_USE_ARC=n
CONFIG_LV_USE_BAR=n
CONFIG_LV_USE_DROPDOWN=n
CONFIG_LV_USE_SLIDER=n
CONFIG_LV_USE_TEXTAREA=n
CONFIG_LV_USE_CANVAS=n
CONFIG_LV_USE_THEME_MONO=n

